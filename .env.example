# ═══════════════════════════════════════════════════════════════════════
#  ERP MDV Oftalmologia — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════════════════
#
#  Copie para .env e edite:  cp .env.example .env
#
#  Railway → Service Variables tab
#  Render  → Service Environment tab
#  Docker  → .env file no root do projeto
# ═══════════════════════════════════════════════════════════════════════

# ═══ DATABASE (OBRIGATÓRIO) ═══════════════════════════════════════════
# Railway:  ${{Postgres.DATABASE_URL}}
# Render:   Internal Database URL no painel do Render Postgres
# Local:    postgresql://user:pass@localhost:5432/erp_mdv?schema=public
DATABASE_URL="postgresql://user:password@host:5432/erp_mdv?schema=public"

# ═══ BACKEND ═════════════════════════════════════════════════════════
NODE_ENV=production
BACKEND_PORT=3001

# ═══ JWT (OBRIGATÓRIO) ══════════════════════════════════════════════
# Gere com: openssl rand -hex 32
JWT_SECRET=TROCAR_OBRIGATORIO_openssl_rand_hex_32
JWT_EXPIRES_IN=24h

# ═══ CORS (OBRIGATÓRIO) ═════════════════════════════════════════════
# URL do frontend, sem barra final. Múltiplas: separar por vírgula
# Exemplo: https://erp-mdv-web.onrender.com,http://localhost:3000
BACKEND_CORS_ORIGIN=https://seu-frontend.com

# ═══ FRONTEND (BUILD-TIME) ══════════════════════════════════════════
# NEXT_PUBLIC_* são injetados no bundle JS no build → build-arg
# Railway: set em Variables (detectado no build automaticamente)
# Render:  set em Environment (disponível no build)
# Docker:  --build-arg NEXT_PUBLIC_API_URL=https://...
NEXT_PUBLIC_API_URL=https://seu-backend.com

# ═══ SEED / DEMO (OPCIONAL) ═════════════════════════════════════════
# true = roda seed no boot (primeiro deploy ou staging)
RUN_SEED=false
ADMIN_DEFAULT_PASSWORD=mdv@2026!

# ═══ AI — CLAUDE (OPCIONAL) ═════════════════════════════════════════
ANTHROPIC_API_KEY=

# ═══ RATE LIMITING (OPCIONAL) ═══════════════════════════════════════
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# ═══ DOCKER COMPOSE LOCAL (OPCIONAL) ════════════════════════════════
DB_USER=erp_user
DB_PASSWORD=erp_pass_trocar_em_producao
